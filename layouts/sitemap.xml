{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{- range .Site.AllPages }}
  {{- if ne .Kind "404" }}
  <url>
    <loc>{{ .Permalink }}</loc>
    <lastmod>{{ (or .Lastmod site.Home.Lastmod).Format "2006-01-02T15:04:05Z07:00" }}</lastmod>
  </url>
  {{- end }}
  {{- end }}
</urlset>
